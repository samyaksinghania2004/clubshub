[run]
branch = False
source =
    tests
    config
omit =
    tests/__init__.py
    tests/unit/*
    tests/system/*
    tests/integration/__init__.py
    config/__init__.py
    config/settings.py
    config/urls.py

[report]
show_missing = True
skip_covered = False
omit =
    tests/__init__.py
    tests/unit/*
    tests/system/*
    tests/integration/__init__.py
    config/__init__.py
    config/settings.py
    config/urls.py
